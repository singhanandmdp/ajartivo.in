rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.admin == true || request.auth.token.role == "admin");
    }

    match /previews/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /secure-downloads/{allPaths=**} {
      allow read, write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
