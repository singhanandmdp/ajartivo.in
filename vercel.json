{
  "headers": [
    {
      "source": "/icons",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, noimageindex"
        }
      ]
    },
    {
      "source": "/icons/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, noimageindex"
        }
      ]
    },
    {
      "source": "/tools/icons",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, noimageindex"
        }
      ]
    },
    {
      "source": "/tools/icons/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, noimageindex"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/product/:path*",
      "destination": "/product.html"
    }
  ]
}
